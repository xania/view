{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "launch kitchensink in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173/",
      "webRoot": "${workspaceFolder}/packages/kitchensink",
      "sourceMaps": true
    },
    {
      "name": "reactivity: test filter",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "--filter",
        "@xania/reactivity",
        "exec",
        "vitest",
        "--run",
        "-t",
        "${input:reactivityTestFilter}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }

    // {
    //   "type": "pwa-chrome",
    //   "request": "launch",
    //   "name": "Launch kitchensink in Chrome",
    //   "url": "http://localhost:5173",
    //   "webRoot": "${workspaceFolder}/packages/kitchensink",
    //   "sourceMaps": true,
    //   "sourceMapPathOverrides": {
    //     "/src/*": "${workspaceFolder}/packages/kitchensink/src/*",
    //     "/@fs/${workspaceFolder}/*": "${workspaceFolder}/*",
    //     "/@fs/*": "*",
    //     "webpack:///*": "${workspaceFolder}/*"
    //   }
    // }
  ],
  "inputs": [
    {
      "id": "reactivityTestFilter",
      "type": "promptString",
      "description": "Vitest test name pattern for @xania/reactivity",
      "default": ""
    }
  ]
}

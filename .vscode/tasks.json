{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "kitchensink: dev",
      "type": "shell",
      "command": "pnpm --filter @xania/kitchensink dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:.*http://localhost:5173"
        }
      }
    }
  ]
}
